<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <!-- Register -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>backend.RegisterServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/RegisterServlet</url-pattern>
    </servlet-mapping>

    <!-- Login -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>backend.LoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>

    <!-- Booking -->
    <servlet>
        <servlet-name>BookingServlet</servlet-name>
        <servlet-class>backend.BookingServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>BookingServlet</servlet-name>
        <url-pattern>/BookingServlet</url-pattern>
    </servlet-mapping>

    <!-- Owner Register -->
    <servlet>
        <servlet-name>OwnerRegisterServlet</servlet-name>
        <servlet-class>backend.OwnerRegisterServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>OwnerRegisterServlet</servlet-name>
        <url-pattern>/OwnerRegisterServlet</url-pattern>
    </servlet-mapping>

    <!-- Owner Login -->
    <servlet>
        <servlet-name>OwnerLoginServlet</servlet-name>
        <servlet-class>backend.OwnerLoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>OwnerLoginServlet</servlet-name>
        <url-pattern>/OwnerLoginServlet</url-pattern>
    </servlet-mapping>

    <!-- Add Equipment -->
    <servlet>
        <servlet-name>AddEquipmentServlet</servlet-name>
        <servlet-class>backend.AddEquipmentServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>AddEquipmentServlet</servlet-name>
        <url-pattern>/AddEquipmentServlet</url-pattern>
    </servlet-mapping>

    <!-- Equipment -->
    <servlet>
        <servlet-name>EquipmentServlet</servlet-name>
        <servlet-class>backend.EquipmentServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>EquipmentServlet</servlet-name>
        <url-pattern>/EquipmentServlet</url-pattern>
    </servlet-mapping>

    <!-- View Users -->
    <servlet>
        <servlet-name>ViewUsersServlet</servlet-name>
        <servlet-class>backend.ViewUsersServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>ViewUsersServlet</servlet-name>
        <url-pattern>/ViewUsersServlet</url-pattern>
    </servlet-mapping>

    <!-- View Owners -->
    <servlet>
        <servlet-name>ViewOwnersServlet</servlet-name>
        <servlet-class>backend.ViewOwnersServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>ViewOwnersServlet</servlet-name>
        <url-pattern>/ViewOwnersServlet</url-pattern>
    </servlet-mapping>

    <!-- View Booking -->
    <servlet>
        <servlet-name>ViewBookingServlet</servlet-name>
        <servlet-class>backend.ViewBookingServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>ViewBookingServlet</servlet-name>
        <url-pattern>/ViewBookingServlet</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>frontend/index.html</welcome-file>
    </welcome-file-list>

</web-app>